# Copy this to `.env` (gitignored) and fill in your values.
# Bun auto-loads `.env` from the repo root, so `bun run apps/cli/src/main.ts …`
# and `./bin/rivet …` pick these up with no per-command prefix.
#
# Jira Cloud REST auth is HTTP Basic: base64(JIRA_EMAIL:JIRA_API_TOKEN).
# The same three vars are used in CI, sourced from Actions secrets (ideally a
# dedicated Jira service-account token so minted issues are attributed to a bot).

JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_BASE_URL=https://jiradg.atlassian.net
